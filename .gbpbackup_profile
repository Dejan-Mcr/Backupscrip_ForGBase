#!/bin/bash
#===============================================================================
#          FILE: .gbpbackup_profile
#         USAGE: source .gbpbackup_profile(auto-sourced by gbpbackup)
#   DESCRIPTION: gbpbackup 备份脚本配置文件
#       OPTIONS: 详见下方各配置区块，根据实际环境修改以下参数，带 * 号为必填项
#===============================================================================

#===============================================================================
# [0] 获取脚本(配置文件)所在目录的绝对路径
#===============================================================================
if [[ -z "${SCRIPT_DIR+x}" ]]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)" || SCRIPT_DIR="$(pwd)"
fi

#===============================================================================
# [1] 备份保留策略配置
#===============================================================================
# *保留的完整备份(FULL类型)最小数量（脚本内置默认：2）
export retention_redundancy=2

# 基于时间的可恢复范围（单位：天，0=禁用时间保留策略，脚本内置默认：7）
export retention_window=7

#===============================================================================
# [2] 目录路径配置
#===============================================================================
# *备份存储目录（脚本内置默认：脚本所在目录下的 backups 文件夹）
export backups_dir="${SCRIPT_DIR}/backups"

# 日志存储目录（脚本内置默认：脚本所在目录下的 logs 文件夹）
export logs_dir="${SCRIPT_DIR}/logs"

# 日志保留天数（脚本内置默认：60 天）
export log_retention_time=60

#===============================================================================
# [3] 数据库连接配置
#===============================================================================
# *数据库实例名称（脚本内置默认：gbase）
export instance_name="gbase"

# *数据库服务端口（脚本内置默认：15400）
export db_port=15400

#===============================================================================
# [4] 备份执行参数配置
#===============================================================================
# *备份并行线程数
export backup_threads="$(( ( $(nproc 2>/dev/null || echo 2) + 1 ) / 2 ))"

# *压缩等级（0=无压缩，1=最快，9=最高压缩，脚本内置默认：5）
export compress_level=5

#===============================================================================
# [5] XLOG (WAL) 归档配置 [可选]
#===============================================================================
# XLOG 归档保留天数（脚本内置默认：7 天）
export retention_days=7

# XLOG 归档存储路径（脚本内置默认：${backups_dir}/wal/${instance_name}）
export archive_dir="${backups_dir}/wal/${instance_name}"

#===============================================================================
# [6] 是否启用备机执行备份（脚本内置默认：false）
#===============================================================================
export is_standby_backup=false

#===============================================================================
# [7] 远程备份配置 [如需远程备份则必填]
#===============================================================================
# *远程数据库认证用户
export dbauser="gsadmin"

# *远程数据库密码
export dbpasswd=""

# *远程数据库主机 IP
export remote_host="192.168.123.120"

# *远程 SSH 连接用户
export remote_user="gbase"

# 远程 SSH 端口（脚本内置默认：22）
export remote_port=22
